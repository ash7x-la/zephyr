# API Keys for DeepSeek Agent Assistant
# Copy this file to .env and fill in your keys

# OpenRouter (Supports DeepSeek, GPT-4, etc.)
OPENROUTER_API_KEY=

# Google Gemini (Direct SDK)
GEMINI_API_KEY=your_gemini_key_here

# Anthropic Claude (Direct SDK)
CLAUDE_API_KEY=your_claude_key_here

# Default Model Settings
# Local DeepSeek Free API (userToken)
DEEPSEEK_FREE_TOKEN=your_deeseek_usertoken_here
DEEPSEEK_FREE_URL=http://127.0.0.1:8000/v1
